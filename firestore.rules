rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isFounder() {
      return isAuthenticated() && (
        request.auth.uid == "yt5Vi0mPs2aag2ENJZu1mw0Nowz2" || 
        request.auth.token.email == "sapientman46@gmail.com" ||
        (userExists() && (getUserData().get('role', '') == 'Founder' || getUserData().get('email', '') == "sapientman46@gmail.com"))
      );
    }

    function isMarketingManager() {
      return isAuthenticated() && userExists() && 
             (getUserData().get('role', '') == 'Marketing Manager' || getUserData().get('role', '') == 'Marketing');
    }

    function isSuperAdmin() {
      // Direct UID/Email check for absolute priority
      return isAuthenticated() && (
        request.auth.uid == "yt5Vi0mPs2aag2ENJZu1mw0Nowz2" || 
        request.auth.token.email == "sapientman46@gmail.com" ||
        isFounder() || 
        isMarketingManager()
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getCompanyData(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data;
    }
    
    function isCompanyMember(companyId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (companyId != null && companyId != "" && userExists() && getUserData().get('companyId', '') == companyId) ||
        (companyId != null && companyId != "" && exists(/databases/$(database)/documents/companies/$(companyId)) && 
         (get(/databases/$(database)/documents/companies/$(companyId)).data.get('ownerId', '') == request.auth.uid || 
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('createdBy', '') == request.auth.uid))
      );
    }
    
    function isCompanyAdmin(companyId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (companyId != null && companyId != "" && userExists() && getUserData().get('companyId', '') == companyId && 
         (getUserData().get('role', '') in ['Admin', 'Founder', 'Marketing Manager'])) ||
        (companyId != null && companyId != "" && exists(/databases/$(database)/documents/companies/$(companyId)) && 
         (get(/databases/$(database)/documents/companies/$(companyId)).data.get('ownerId', '') == request.auth.uid || 
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('createdBy', '') == request.auth.uid))
      );
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (userExists() && getUserData().get('permissions', []).contains(permission))
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Subscription Plans - Move to top for priority
    match /subscription_plans/{planId} {
      allow get, list: if true;
      allow write: if isFounder() || isMarketingManager();
    }

    // System Configuration
    match /system/{document} {
      allow read: if true; // Allow public read for UI/UX settings
      allow write: if isFounder();
    }

    // Settings
    match /settings/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow write: if isCompanyAdmin(companyId);
      allow delete: if isSuperAdmin() || isCompanyAdmin(companyId);
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        resource == null ||
        (resource != null && (resource.data.ownerId == request.auth.uid || resource.data.createdBy == request.auth.uid)) ||
        (userExists() && getUserData().get('companyId', '') == companyId && resource.data.get('isAccessEnabled', true) != false)
      );
      allow create: if isAuthenticated();
      allow update: if isCompanyAdmin(companyId);
      allow delete: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // User Profiles
    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || 
        isSuperAdmin() || 
        (userExists() && getUserData().companyId == resource.data.companyId)
      );
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == uid || 
        (userExists() && isCompanyAdmin(resource.data.companyId))
      );
      allow delete: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == uid);
    }

    // ERP Data
    match /ledgers/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /items/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /vouchers/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /ledger_groups/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /voucher_entries/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /inventory_entries/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /units/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /godowns/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /employees/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /salary_sheets/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /advances/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /loans/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /stock_groups/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /stock_categories/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /voucher_types/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /employee_groups/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /pay_heads/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyAdmin(request.resource.data.companyId);
      allow update: if isCompanyAdmin(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /salary_structures/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyAdmin(request.resource.data.companyId);
      allow update: if isCompanyAdmin(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /attendance/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(request.resource.data.companyId);
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }
    
    match /orders/{id} {
      allow read: if isCompanyMember(resource.data.companyId) && (hasPermission('orders') || isCompanyAdmin(resource.data.companyId));
      allow create: if isCompanyMember(request.resource.data.companyId) && (hasPermission('orders') || isCompanyAdmin(request.resource.data.companyId));
      allow update: if isCompanyMember(request.resource.data.companyId) && (hasPermission('orders') || isCompanyAdmin(request.resource.data.companyId));
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /machines/{id} {
      allow read: if isCompanyMember(resource.data.companyId) && (hasPermission('machines') || isCompanyAdmin(resource.data.companyId));
      allow create: if isCompanyMember(request.resource.data.companyId) && (hasPermission('machines') || isCompanyAdmin(request.resource.data.companyId));
      allow update: if isCompanyMember(request.resource.data.companyId) && (hasPermission('machines') || isCompanyAdmin(request.resource.data.companyId));
      allow delete: if isCompanyAdmin(resource.data.companyId) || isSuperAdmin();
    }

    match /activity_log/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(resource.data.companyId));
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    match /notifications/{id} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (resource != null && (
          resource.data.get('targetType', '') == 'all' ||
          (resource.data.get('targetType', '') == 'company' && resource.data.get('targetId', '') == getUserData().get('companyId', '')) ||
          (resource.data.get('targetType', '') == 'user' && resource.data.get('targetId', '') == request.auth.uid)
        ))
      );
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        isAuthenticated() && 
        (resource != null && resource.data.get('targetType', '') == 'user' && resource.data.get('targetId', '') == request.auth.uid) ||
        (resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']))
      );
      allow delete: if isSuperAdmin();
    }

    // Site Content (Landing Pages)
    match /site_content/{pageId} {
      allow read: if true; // Public read for landing pages
      allow write: if isFounder();
    }

    // Subscription Orders
    match /subscription_orders/{orderId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (resource != null && (resource.data.requestedBy == request.auth.uid || isCompanyAdmin(resource.data.companyId)))
      );
      allow create: if isAuthenticated() && 
                    request.resource.data.requestedBy == request.auth.uid &&
                    isCompanyAdmin(request.resource.data.companyId);
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (resource != null && resource.data.requestedBy == request.auth.uid && resource.data.status == 'pending' && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'notes', 'updatedAt']) &&
         request.resource.data.status == 'cancelled')
      );
      allow delete: if isSuperAdmin();
    }
  }
}
