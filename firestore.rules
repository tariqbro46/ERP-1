rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isFounder() {
      return isAuthenticated() && (
        request.auth.uid == "yt5Vi0mPs2aag2ENJZu1mw0Nowz2" || 
        request.auth.token.get('email', '') == "sapientman46@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Founder' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') == "sapientman46@gmail.com"))
      );
    }

    function isMarketingManager() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Marketing Manager' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Marketing')
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "yt5Vi0mPs2aag2ENJZu1mw0Nowz2" || 
        request.auth.token.get('email', '') == "sapientman46@gmail.com" ||
        isFounder() || 
        isMarketingManager()
      );
    }

    function getUserCompanyId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('companyId', '') : '';
    }

    function isCompanyMember(companyId) {
      return isAuthenticated() && companyId != null && companyId != "" && (
        isSuperAdmin() || 
        (companyId == request.auth.uid) || 
        (getUserCompanyId() == companyId) ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) && (
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('ownerId', '') == request.auth.uid || 
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('createdBy', '') == request.auth.uid
        ))
      );
    }
    
    function isCompanyAdmin(companyId) {
      return isAuthenticated() && companyId != null && companyId != "" && (
        isSuperAdmin() || 
        (companyId == request.auth.uid) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('companyId', '') == companyId && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['Admin', 'Founder', 'Marketing Manager']) ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) && (
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('ownerId', '') == request.auth.uid || 
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('createdBy', '') == request.auth.uid
        ))
      );
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', []).contains(permission))
      );
    }

    function isVerified() {
      return isAuthenticated();
    }
    
    // ===============================================================
    // Rules
    // ===============================================================

    match /subscription_plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /system/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/{companyId} {
      allow read: if isAuthenticated() && isCompanyMember(companyId);
      allow write: if isAuthenticated() && isCompanyAdmin(companyId);
      
      match /{configPath=**} {
        allow read: if isAuthenticated() && isCompanyMember(companyId);
        allow write: if isAuthenticated() && isCompanyAdmin(companyId);
      }
    }

    match /companies/{companyId} {
      allow get: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(companyId));
      allow list: if isAuthenticated() && (isSuperAdmin() || resource.data.get('ownerId', '') == request.auth.uid || resource.data.get('createdBy', '') == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || resource.data.get('ownerId', '') == request.auth.uid);
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || 
        isSuperAdmin() || 
        (resource != null && isCompanyMember(resource.data.get('companyId', '')))
      );
      allow create, update: if isAuthenticated() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Master Data & Vouchers
    match /ledgers/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /items/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /vouchers/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /ledger_groups/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /voucher_entries/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /inventory_entries/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /units/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /godowns/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /godown_stock/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /employees/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /salary_sheets/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /advances/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /loans/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /stock_groups/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /stock_categories/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /voucher_types/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /employee_groups/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /pay_heads/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyAdmin(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    function isCompanyAdminSimple(companyId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('companyId', '') == companyId && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['Admin', 'Founder', 'Marketing Manager'];
    }

    match /salary_structures/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyAdmin(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /attendance/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isCompanyMember(resource.data.get('companyId', '')));
      allow write: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }
    
    match /orders/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && isCompanyMember(resource.data.get('companyId', '')) && (hasPermission('orders') || isCompanyAdminSimple(resource.data.get('companyId', '')))));
      allow write: if isAuthenticated() && (isSuperAdmin() || (isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))) && (hasPermission('orders') || isCompanyAdminSimple(request.resource.data.get('companyId', resource.data.get('companyId', ''))))));
    }

    match /machines/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && isCompanyMember(resource.data.get('companyId', '')) && (hasPermission('machines') || isCompanyAdminSimple(resource.data.get('companyId', '')))));
      allow write: if isAuthenticated() && (isSuperAdmin() || (isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))) && (hasPermission('machines') || isCompanyAdminSimple(request.resource.data.get('companyId', resource.data.get('companyId', ''))))));
    }

    match /activity_log/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(resource.data.get('companyId', '')));
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    match /counters/{id} {
      allow read, write: if isAuthenticated() && (isSuperAdmin() || id.startsWith(request.auth.uid) || isCompanyMember(request.resource.data.get('companyId', resource.data.get('companyId', ''))));
    }

    match /notifications/{id} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (resource != null && (
          resource.data.get('targetType', '') == 'all' ||
          (resource.data.get('targetType', '') == 'company' && resource.data.get('targetId', '') == getUserCompanyId()) ||
          (resource.data.get('targetType', '') == 'user' && resource.data.get('targetId', '') == request.auth.uid)
        ))
      );
      allow write: if isSuperAdmin();
      allow update: if isAuthenticated() && resource != null && resource.data.targetId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
    }

    match /site_content/{pageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /error_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSuperAdmin();
    }

    match /subscription_orders/{orderId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // Default deny ALL remaining
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
