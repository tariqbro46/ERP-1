rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isFounder() {
      return isAuthenticated() && (
        request.auth.uid == "yt5Vi0mPs2aag2ENJZu1mw0Nowz2" || 
        request.auth.uid == "vyF2U9sucLc7vYLOUX6Jh9jrtC02" ||
        request.auth.token.email == "sapientman46@gmail.com" ||
        request.auth.token.email == "arifulislamoffice35@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Founder')
      );
    }

    // Optimization: SuperAdmin check without DB reads for hardcoded users
    function isSuperAdminBasic() {
      return isAuthenticated() && (
        request.auth.uid == "yt5Vi0mPs2aag2ENJZu1mw0Nowz2" || 
        request.auth.uid == "vyF2U9sucLc7vYLOUX6Jh9jrtC02" ||
        request.auth.token.email == "sapientman46@gmail.com" ||
        request.auth.token.email == "arifulislamoffice35@gmail.com"
      );
    }

    function isSuperAdmin() {
      return isSuperAdminBasic() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().get('role', '') in ['Founder', 'Admin', 'Marketing Manager', 'Marketing']
      );
    }

    function getCompanyId(data) {
      return data.get('companyId', data.get('company_id', ''));
    }

    function getUserCompanyId() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
             getCompanyId(getUserData()) : '';
    }

    function isCompanyMember(companyId) {
      return isAuthenticated() && (companyId != null && companyId != "") && (
        isSuperAdminBasic() || 
        (companyId == request.auth.uid) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('companyId', '') == companyId) ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) && (
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('ownerId', '') == request.auth.uid || 
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('createdBy', '') == request.auth.uid
        ))
      );
    }
    
    function isCompanyAdmin(companyId) {
      return isAuthenticated() && (companyId != null && companyId != "") && (
        isSuperAdminBasic() || 
        (companyId == request.auth.uid) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          getUserData().get('companyId', '') == companyId && 
          getUserData().get('role', '') in ['Admin', 'Founder', 'Marketing Manager']
        )) ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) && (
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('ownerId', '') == request.auth.uid || 
          get(/databases/$(database)/documents/companies/$(companyId)).data.get('createdBy', '') == request.auth.uid
        ))
      );
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().get('permissions', []).contains(permission))
      );
    }

    function isVerified() {
      return isAuthenticated();
    }

    function getEffectiveCompanyId() {
      return request.resource != null ? getCompanyId(request.resource.data) : 
             (resource != null ? getCompanyId(resource.data) : '');
    }

    function isCompanyAdminSimple(companyId) {
      return isCompanyAdmin(companyId);
    }
    
    // ===============================================================
    // Rules
    // ===============================================================

    match /subscription_plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /system/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/{companyId} {
      allow read: if isAuthenticated() && isCompanyMember(companyId);
      allow write: if isAuthenticated() && isCompanyAdmin(companyId);
      
      match /{configPath=**} {
        allow read: if isAuthenticated() && isCompanyMember(companyId);
        allow write: if isAuthenticated() && isCompanyAdmin(companyId);
      }
    }

    match /companies/{companyId} {
      allow get: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(companyId));
      allow list: if isAuthenticated() && (isSuperAdmin() || resource.data.get('ownerId', '') == request.auth.uid || resource.data.get('createdBy', '') == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || resource.data.get('ownerId', '') == request.auth.uid);
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || 
        isSuperAdmin() || 
        (resource != null && isCompanyMember(resource.data.get('companyId', '')))
      );
      allow create, update: if isAuthenticated() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    function isOwner(data) {
      return data != null && (
        data.get('ownerId', '') == request.auth.uid || 
        data.get('createdBy', '') == request.auth.uid || 
        data.get('userId', '') == request.auth.uid ||
        data.get('uid', '') == request.auth.uid
      );
    }

    match /ledger_groups/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /ledgers/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /items/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /vouchers/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /voucher_entries/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /inventory_entries/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /units/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /godowns/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /godown_stock/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /employees/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /salary_sheets/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /advances/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /loans/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /stock_groups/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /stock_categories/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /voucher_types/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /employee_groups/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /pay_heads/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyAdmin(getEffectiveCompanyId()));
    }

    match /salary_structures/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyAdmin(getEffectiveCompanyId()));
    }

    match /attendance/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }
    
    match /orders/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && (isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data))) && (hasPermission('orders') || isCompanyAdminSimple(getCompanyId(resource.data)))));
      allow write: if isAuthenticated() && (isSuperAdmin() || ((isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId())) && (hasPermission('orders') || isCompanyAdminSimple(getEffectiveCompanyId()))));
    }

    match /machines/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && (isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data))) && (hasPermission('machines') || isCompanyAdminSimple(getCompanyId(resource.data)))));
      allow write: if isAuthenticated() && (isSuperAdmin() || ((isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId())) && (hasPermission('machines') || isCompanyAdminSimple(getEffectiveCompanyId()))));
    }

    match /serial_numbers/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /tax_rates/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /leads/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /interactions/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /purchase_orders/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /batches/{id} {
      allow list: if isSuperAdminBasic() || (isAuthenticated() && resource.data.get('companyId', '') == request.auth.uid);
      allow get: if isAuthenticated() && (isSuperAdmin() || resource == null || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow write: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /activity_log/{id} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data) || isCompanyMember(getCompanyId(resource.data)));
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    match /counters/{id} {
      allow read, write: if isAuthenticated() && (isSuperAdmin() || id.startsWith(request.auth.uid) || isOwner(resource.data) || isOwner(request.resource.data) || isCompanyMember(getEffectiveCompanyId()));
    }

    match /notifications/{id} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (resource != null && (
          resource.data.get('targetType', '') == 'all' ||
          (resource.data.get('targetType', '') == 'company' && resource.data.get('targetId', '') == getUserCompanyId()) ||
          (resource.data.get('targetType', '') == 'user' && resource.data.get('targetId', '') == request.auth.uid)
        ))
      );
      allow write: if isSuperAdmin();
      allow update: if isAuthenticated() && resource != null && resource.data.targetId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
    }

    match /site_content/{pageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /error_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSuperAdmin();
    }

    match /subscription_orders/{orderId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, delete: if isSuperAdmin();
    }

    // Default deny ALL remaining
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
