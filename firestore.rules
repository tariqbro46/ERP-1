rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
             'email' in request.auth.token &&
             request.auth.token.email == "sapientman46@gmail.com";
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function isCompanyMember(companyId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (userExists() && 'companyId' in getUserData() && getUserData().companyId == companyId) ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid)
      );
    }
    
    function isCompanyAdmin(companyId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (userExists() && 'companyId' in getUserData() && getUserData().companyId == companyId && 'role' in getUserData() && getUserData().role == 'admin') ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid)
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Settings
    match /settings/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow write: if isCompanyAdmin(companyId);
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        isCompanyMember(companyId) || 
        resource.data.ownerId == request.auth.uid || 
        resource.data.createdBy == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isCompanyAdmin(companyId);
    }

    // User Profiles
    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || 
        isSuperAdmin() || 
        (userExists() && getUserData().companyId == resource.data.companyId)
      );
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == uid || 
        (userExists() && isCompanyAdmin(resource.data.companyId))
      );
    }

    // ERP Data
    match /ledgers/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /items/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /vouchers/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /ledger_groups/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /voucher_entries/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /inventory_entries/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /units/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /godowns/{id} {
      allow read: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(request.resource.data.companyId);
    }

    match /activity_log/{id} {
      allow read: if isCompanyAdmin(resource.data.companyId);
      allow create: if isAuthenticated() && request.resource.data.companyId == getUserData().companyId;
    }
  }
}
