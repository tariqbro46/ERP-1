{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Represents a business entity in the ERP system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "companyId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "companyId", "role"]
    },
    "LedgerGroup": {
      "title": "Ledger Group",
      "description": "Classification for ledgers (e.g., Assets, Liabilities).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "nature": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "Ledger": {
      "title": "Ledger",
      "description": "An account in the chart of accounts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "group_id": { "type": "string" },
        "companyId": { "type": "string" },
        "opening_balance": { "type": "number" },
        "current_balance": { "type": "number" }
      },
      "required": ["name", "group_id", "companyId"]
    },
    "Unit": {
      "title": "Unit",
      "description": "Unit of measurement for items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "formal_name": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "Godown": {
      "title": "Godown",
      "description": "Warehouse or storage location.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "Item": {
      "title": "Item",
      "description": "Inventory item or product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit_id": { "type": "string" },
        "companyId": { "type": "string" },
        "current_stock": { "type": "number" }
      },
      "required": ["name", "unit_id", "companyId"]
    },
    "Voucher": {
      "title": "Voucher",
      "description": "Financial or inventory transaction header.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "v_no": { "type": "string" },
        "v_type": { "type": "string" },
        "v_date": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["v_no", "v_type", "v_date", "companyId"]
    },
    "VoucherEntry": {
      "title": "Voucher Entry",
      "description": "Accounting entry within a voucher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "voucher_id": { "type": "string" },
        "ledger_id": { "type": "string" },
        "debit": { "type": "number" },
        "credit": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["voucher_id", "ledger_id", "companyId"]
    },
    "InventoryEntry": {
      "title": "Inventory Entry",
      "description": "Stock movement entry within a voucher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "voucher_id": { "type": "string" },
        "item_id": { "type": "string" },
        "qty": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["voucher_id", "item_id", "companyId"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Log of user actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "companyId"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Represents an employee in the company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "department": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bloodGroup": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "O+", "O-", "AB+", "AB-"] },
        "presentAddress": { "type": "string" },
        "permanentAddress": { "type": "string" },
        "nidNumber": { "type": "string" },
        "drivingLicense": { "type": "string" },
        "passportNo": { "type": "string" },
        "bankName": { "type": "string" },
        "bankBranch": { "type": "string" },
        "bankAccountNumber": { "type": "string" },
        "bankRoutingNumber": { "type": "string" },
        "emergencyContactName": { "type": "string" },
        "emergencyContactRelation": { "type": "string" },
        "emergencyContactPhone": { "type": "string" },
        "emergencyContact2Name": { "type": "string" },
        "emergencyContact2Relation": { "type": "string" },
        "emergencyContact2Phone": { "type": "string" },
        "emergencyContact3Name": { "type": "string" },
        "emergencyContact3Relation": { "type": "string" },
        "emergencyContact3Phone": { "type": "string" },
        "joining_date": { "type": "string", "format": "date" },
        "salary": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "On Leave"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "companyId"]
    },
    "SalarySheet": {
      "title": "Salary Sheet",
      "description": "Monthly salary record for an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "month": { "type": "string" },
        "basicSalary": { "type": "number" },
        "netSalary": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Pending", "Paid"] }
      },
      "required": ["companyId", "employeeId", "month", "netSalary"]
    },
    "Advance": {
      "title": "Advance",
      "description": "Employee advance payment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "amount": { "type": "number" },
        "applicationDate": { "type": "string", "format": "date" },
        "approvalDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Deducted", "Cancelled"] }
      },
      "required": ["companyId", "employeeId", "amount"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Employee loan record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "amount": { "type": "number" },
        "interestRate": { "type": "number" },
        "emiDuration": { "type": "integer" },
        "monthlyEMI": { "type": "number" },
        "remainingBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Closed", "Cancelled"] }
      },
      "required": ["companyId", "employeeId", "amount", "remainingBalance"]
    },
    "Settings": {
      "title": "Settings",
      "description": "System-wide settings for a company.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" },
        "slogan": { "type": "string" },
        "menuBarStyle": { "type": "string", "enum": ["classic", "ribbon", "macos", "windows11"] },
        "layoutWidth": { "type": "string", "enum": ["responsive", "constrained"] },
        "sidebarDefaultExpanded": { "type": "boolean" },
        "baseCurrencySymbol": { "type": "string" },
        "timezone": { "type": "string" }
      },
      "required": ["companyName"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications and messages from the Founder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["system", "update", "announcement"] },
        "targetType": { "type": "string", "enum": ["all", "company", "user"] },
        "targetId": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "sentAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "sent"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "targetType", "status", "createdBy", "createdAt"]
    },
    "PrintingOrder": {
      "title": "Printing Order",
      "description": "Represents a production order for packaging printing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "printDesign": { "type": "string" },
        "quantity": { "type": "number" },
        "printType": { "type": "string", "enum": ["Analog", "Digital"] },
        "isDoubleSided": { "type": "boolean" },
        "deliveryDate": { "type": "string", "format": "date" },
        "deliveryTime": { "type": "string" },
        "deliveryLocation": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Printing", "Completed", "Delivered", "Cancelled"] },
        "price": { "type": "number" },
        "machineId": { "type": "string" },
        "machineName": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "clientId", "clientName", "itemName", "quantity", "status"]
    },
    "PrintingMachine": {
      "title": "Printing Machine",
      "description": "Represents a printing machine in the production facility.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Analog", "Digital", "Both"] },
        "status": { "type": "string", "enum": ["Idle", "Busy", "Maintenance"] },
        "currentOrderId": { "type": "string" },
        "lastMaintenance": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "name", "type", "status"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global application-wide settings controlled by the Founder.",
      "type": "object",
      "properties": {
        "statusOnlineText": { "type": "string" },
        "statusOfflineText": { "type": "string" },
        "statusErrorText": { "type": "string" },
        "appVersion": { "type": "string" }
      }
    },
    "SiteContent": {
      "title": "Site Content",
      "description": "Content for public-facing pages (Home, About, etc.)",
      "type": "object",
      "properties": {
        "pageId": { "type": "string" },
        "content": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pageId", "content"]
    }
  },
  "firestore": {
    "/site_content/{pageId}": {
      "schema": "SiteContent",
      "description": "Content for landing pages."
    },
    "/system/config": {
      "schema": "SystemConfig",
      "description": "Global application configuration."
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Collection of companies."
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/settings/{companyId}": {
      "schema": "Settings",
      "description": "System settings for each company."
    },
    "/ledger_groups/{id}": {
      "schema": "LedgerGroup",
      "description": "Collection of ledger groups."
    },
    "/ledgers/{id}": {
      "schema": "Ledger",
      "description": "Collection of ledgers."
    },
    "/units/{id}": {
      "schema": "Unit",
      "description": "Collection of units."
    },
    "/godowns/{id}": {
      "schema": "Godown",
      "description": "Collection of godowns."
    },
    "/items/{id}": {
      "schema": "Item",
      "description": "Collection of items."
    },
    "/vouchers/{id}": {
      "schema": "Voucher",
      "description": "Collection of vouchers."
    },
    "/voucher_entries/{id}": {
      "schema": "VoucherEntry",
      "description": "Collection of voucher entries."
    },
    "/inventory_entries/{id}": {
      "schema": "InventoryEntry",
      "description": "Collection of inventory entries."
    },
    "/activity_log/{id}": {
      "schema": "ActivityLog",
      "description": "Collection of activity logs."
    },
    "/employees/{id}": {
      "schema": "Employee",
      "description": "Collection of employees."
    },
    "/salary_sheets/{id}": {
      "schema": "SalarySheet",
      "description": "Collection of salary sheets."
    },
    "/advances/{id}": {
      "schema": "Advance",
      "description": "Collection of employee advances."
    },
    "/loans/{id}": {
      "schema": "Loan",
      "description": "Collection of employee loans."
    },
    "/notifications/{id}": {
      "schema": "Notification",
      "description": "Global notifications collection."
    },
    "/orders/{id}": {
      "schema": "PrintingOrder",
      "description": "Collection of production orders."
    },
    "/machines/{id}": {
      "schema": "PrintingMachine",
      "description": "Collection of printing machines."
    }
  }
}
