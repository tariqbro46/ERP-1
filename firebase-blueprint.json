{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Represents a business entity in the ERP system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "companyId": { "type": "string" },
        "role": { "type": "string", "enum": ["Founder", "Marketing Manager", "Admin", "Manager", "Staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "companyId", "role"]
    },
    "LedgerGroup": {
      "title": "Ledger Group",
      "description": "Classification for ledgers (e.g., Assets, Liabilities).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "nature": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "Ledger": {
      "title": "Ledger",
      "description": "An account in the chart of accounts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "group_id": { "type": "string" },
        "companyId": { "type": "string" },
        "opening_balance": { "type": "number" },
        "current_balance": { "type": "number" }
      },
      "required": ["name", "group_id", "companyId"]
    },
    "Unit": {
      "title": "Unit",
      "description": "Unit of measurement for items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "formal_name": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "Godown": {
      "title": "Godown",
      "description": "Warehouse or storage location.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "GodownStock": {
      "title": "Godown Stock",
      "description": "Stock levels for an item in a specific godown.",
      "type": "object",
      "properties": {
        "godown_id": { "type": "string" },
        "item_id": { "type": "string" },
        "companyId": { "type": "string" },
        "current_stock": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["godown_id", "item_id", "companyId", "current_stock"]
    },
    "Item": {
      "title": "Item",
      "description": "Inventory item or product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit_id": { "type": "string" },
        "companyId": { "type": "string" },
        "current_stock": { "type": "number" }
      },
      "required": ["name", "unit_id", "companyId"]
    },
    "Voucher": {
      "title": "Voucher",
      "description": "Financial or inventory transaction header.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "v_no": { "type": "string" },
        "serial_no": { "type": "number" },
        "auto_serial_no": { "type": "number" },
        "reference_no": { "type": "string" },
        "v_type": { "type": "string" },
        "v_date": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["v_no", "v_type", "v_date", "companyId"]
    },
    "VoucherEntry": {
      "title": "Voucher Entry",
      "description": "Accounting entry within a voucher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "voucher_id": { "type": "string" },
        "ledger_id": { "type": "string" },
        "debit": { "type": "number" },
        "credit": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["voucher_id", "ledger_id", "companyId"]
    },
    "InventoryEntry": {
      "title": "Inventory Entry",
      "description": "Stock movement entry within a voucher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "voucher_id": { "type": "string" },
        "item_id": { "type": "string" },
        "qty": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["voucher_id", "item_id", "companyId"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Log of user actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "companyId"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Represents an employee in the company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "department": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bloodGroup": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "O+", "O-", "AB+", "AB-"] },
        "presentAddress": { "type": "string" },
        "permanentAddress": { "type": "string" },
        "nidNumber": { "type": "string" },
        "drivingLicense": { "type": "string" },
        "passportNo": { "type": "string" },
        "bankName": { "type": "string" },
        "bankBranch": { "type": "string" },
        "bankAccountNumber": { "type": "string" },
        "bankRoutingNumber": { "type": "string" },
        "emergencyContactName": { "type": "string" },
        "emergencyContactRelation": { "type": "string" },
        "emergencyContactPhone": { "type": "string" },
        "emergencyContact2Name": { "type": "string" },
        "emergencyContact2Relation": { "type": "string" },
        "emergencyContact2Phone": { "type": "string" },
        "emergencyContact3Name": { "type": "string" },
        "emergencyContact3Relation": { "type": "string" },
        "emergencyContact3Phone": { "type": "string" },
        "joining_date": { "type": "string", "format": "date" },
        "salary": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "On Leave"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "companyId"]
    },
    "PayHead": {
      "title": "Pay Head",
      "description": "Definition of a salary component (e.g., Basic, HRA, PF).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Earning", "Deduction"] },
        "calculationType": { "type": "string", "enum": ["Fixed", "On Attendance", "Percentage"] },
        "companyId": { "type": "string" }
      },
      "required": ["name", "type", "calculationType", "companyId"]
    },
    "SalaryStructure": {
      "title": "Salary Structure",
      "description": "Links pay heads to an employee with specific values.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "payHeadId": { "type": "string" },
        "amount": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["employeeId", "payHeadId", "amount", "companyId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record for an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Leave", "Half Day", "Holiday"] },
        "overtimeHours": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["employeeId", "date", "status", "companyId"]
    },
    "SalarySheet": {
      "title": "Salary Sheet",
      "description": "Monthly salary record for an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "month": { "type": "string" },
        "basicSalary": { "type": "number" },
        "netSalary": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Pending", "Paid"] }
      },
      "required": ["companyId", "employeeId", "month", "netSalary"]
    },
    "Advance": {
      "title": "Advance",
      "description": "Employee advance payment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "amount": { "type": "number" },
        "applicationDate": { "type": "string", "format": "date" },
        "approvalDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Deducted", "Cancelled"] }
      },
      "required": ["companyId", "employeeId", "amount"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Employee loan record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "amount": { "type": "number" },
        "interestRate": { "type": "number" },
        "emiDuration": { "type": "integer" },
        "monthlyEMI": { "type": "number" },
        "remainingBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Closed", "Cancelled"] }
      },
      "required": ["companyId", "employeeId", "amount", "remainingBalance"]
    },
    "StockGroup": {
      "title": "Stock Group",
      "description": "Classification for stock items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "StockCategory": {
      "title": "Stock Category",
      "description": "Category for stock items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "VoucherType": {
      "title": "Voucher Type",
      "description": "Type of voucher (e.g., Sales, Purchase, Payment).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "base_type": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "base_type", "companyId"]
    },
    "EmployeeGroup": {
      "title": "Employee Group",
      "description": "Classification for employees.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "companyId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "System-wide settings for a company.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" },
        "slogan": { "type": "string" },
        "menuBarStyle": { "type": "string", "enum": ["classic", "ribbon", "macos", "windows11"] },
        "layoutWidth": { "type": "string", "enum": ["responsive", "constrained"] },
        "sidebarDefaultExpanded": { "type": "boolean" },
        "baseCurrencySymbol": { "type": "string" },
        "timezone": { "type": "string" },
        "enableTax": { "type": "boolean" },
        "enableHelpButton": { "type": "boolean" },
        "pwaEnabled": { "type": "boolean" }
      },
      "required": ["companyName"]
    },
    "TaxRate": {
      "title": "Tax Rate",
      "description": "Tax percentages for GST/VAT.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rate": { "type": "number" },
        "type": { "type": "string", "enum": ["GST", "VAT", "Service Tax"] },
        "companyId": { "type": "string" }
      },
      "required": ["name", "rate", "companyId"]
    },
    "Lead": {
      "title": "Lead",
      "description": "CRM Lead or Potential Customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Qualified", "Converted", "Lost"] },
        "assignedTo": { "type": "string" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "companyId"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "CRM activity log for a lead or customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "leadId": { "type": "string" },
        "type": { "type": "string", "enum": ["Call", "Email", "Meeting", "Note"] },
        "details": { "type": "string" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leadId", "type", "companyId"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "description": "PO for supply chain management.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "poNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Received", "Cancelled"] },
        "totalAmount": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["poNumber", "supplierId", "companyId"]
    },
    "Batch": {
      "title": "Batch",
      "description": "Inventory batch tracking with expiry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "batchNumber": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "quantity": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["itemId", "batchNumber", "companyId"]
    },
    "SerialNumber": {
      "title": "Serial Number",
      "description": "Individual item serial number tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "serialNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["In Stock", "Sold", "Returned"] },
        "companyId": { "type": "string" }
      },
      "required": ["itemId", "serialNumber", "companyId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications and messages from the Founder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["system", "update", "announcement"] },
        "targetType": { "type": "string", "enum": ["all", "company", "user"] },
        "targetId": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "sentAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "sent"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "targetType", "status", "createdBy", "createdAt"]
    },
    "PrintingOrder": {
      "title": "Printing Order",
      "description": "Represents a production order for packaging printing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "printDesign": { "type": "string" },
        "quantity": { "type": "number" },
        "printType": { "type": "string", "enum": ["Analog", "Digital"] },
        "isDoubleSided": { "type": "boolean" },
        "deliveryDate": { "type": "string", "format": "date" },
        "deliveryTime": { "type": "string" },
        "deliveryLocation": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Printing", "Completed", "Delivered", "Cancelled"] },
        "price": { "type": "number" },
        "machineId": { "type": "string" },
        "machineName": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "clientId", "clientName", "itemName", "quantity", "status"]
    },
    "PrintingMachine": {
      "title": "Printing Machine",
      "description": "Represents a printing machine in the production facility.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Analog", "Digital", "Both"] },
        "status": { "type": "string", "enum": ["Idle", "Busy", "Maintenance"] },
        "currentOrderId": { "type": "string" },
        "lastMaintenance": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "name", "type", "status"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global application-wide settings controlled by the Founder.",
      "type": "object",
      "properties": {
        "statusOnlineText": { "type": "string" },
        "statusOfflineText": { "type": "string" },
        "statusErrorText": { "type": "string" },
        "appVersion": { "type": "string" }
      }
    },
    "SiteContent": {
      "title": "Site Content",
      "description": "Content for public-facing pages (Home, About, etc.)",
      "type": "object",
      "properties": {
        "pageId": { "type": "string" },
        "content": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pageId", "content"]
    },
    "SubscriptionPlan": {
      "title": "Subscription Plan",
      "description": "Subscription plans for companies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "priceMonthly": { "type": "number" },
        "priceYearly": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "limits": {
          "type": "object",
          "properties": {
            "vouchers": { "type": "integer" },
            "items": { "type": "integer" },
            "ledgers": { "type": "integer" },
            "users": { "type": "integer" },
            "godowns": { "type": "integer" },
            "multiCurrency": { "type": "boolean" },
            "rolePermissions": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "priceMonthly", "priceYearly", "features", "limits"]
    },
    "MenuConfig": {
      "title": "Menu Configuration",
      "description": "Dynamic sidebar menu configuration.",
      "type": "object",
      "properties": {
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "labelKey": { "type": "string" },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ErrorLog": {
      "title": "Error Log",
      "description": "Captured error information for debugging.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "companyId": { "type": "string" },
        "message": { "type": "string" },
        "stack": { "type": "string" },
        "componentName": { "type": "string" },
        "path": { "type": "string" },
        "browserInfo": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
        "status": { "type": "string", "enum": ["new", "investigating", "resolved", "ignored"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["message", "path", "severity", "status", "timestamp"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Visitor contact/help inquiry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message"]
    }
  },
  "firestore": {
    "/error_logs/{id}": {
      "schema": "ErrorLog",
      "description": "Collection of technical error logs."
    },
    "/site_content/{pageId}": {
      "schema": "SiteContent",
      "description": "Content for landing pages."
    },
    "/system/config": {
      "schema": "SystemConfig",
      "description": "Global application configuration."
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Collection of companies."
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/settings/{companyId}": {
      "schema": "Settings",
      "description": "System settings for each company."
    },
    "/ledger_groups/{id}": {
      "schema": "LedgerGroup",
      "description": "Collection of ledger groups."
